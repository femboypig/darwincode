{
  "$schema": "https://raw.githubusercontent.com/femboypig/darwincode/main/theme.json",
  "defs": {
    "bg": "#f0fff0",
    "panel_bg": "#e4f5e4",
    "fg": "#1a3020",
    "fg_muted": "#6a8a70",
    "red": "#aa3333",
    "orange": "#8a5a20",
    "yellow": "#6a6a00",
    "green": "#2a7a2a",
    "teal": "#1a6a5a",
    "blue": "#2a5a8a",
    "magenta": "#6a3a7a",
    "cyan": "#1a6a7a",
    "border": "#c8e0c8"
  },
  "theme": {
    "primary": "green",
    "secondary": "fg_muted",
    "accent": "green",
    "error": "red",
