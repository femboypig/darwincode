    "syntaxComment": "fg_muted",
    "syntaxKeyword": "magenta",
    "syntaxFunction": "blue",
    "syntaxVariable": "fg",
    "syntaxString": "green",
    "syntaxNumber": "orange",
    "syntaxType": "teal",
    "syntaxOperator": "blue",
    "syntaxPunctuation": "fg_muted",
    "markdownHeading": "blue",
    "markdownCode": "teal",
    "markdownStrong": "fg",
    "markdownListItem": "blue"
  }
