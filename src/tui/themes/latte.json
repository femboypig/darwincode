{
  "$schema": "https://raw.githubusercontent.com/femboypig/darwincode/main/theme.json",
  "defs": {
    "bg": "#fff8f0",
    "panel_bg": "#f5ece0",
    "fg": "#2e2a25",
    "fg_muted": "#9a8e80",
    "red": "#b34040",
    "orange": "#a86020",
    "yellow": "#8a6a10",
    "green": "#4a8a2a",
    "teal": "#2a7a6a",
    "blue": "#3a6aaa",
    "magenta": "#7a4a8a",
    "cyan": "#2a7a8a",
    "border": "#e5d8c8"
  },
  "theme": {
    "primary": "orange",
    "secondary": "fg_muted",
    "accent": "orange",
    "error": "red",
    "warning": "orange",
    "success": "green",
    "info": "cyan",
    "text": "fg",
    "textMuted": "fg_muted",
    "background": "bg",
    "backgroundPanel": "panel_bg",
    "backgroundElement": "panel_bg",
    "border": "border",
    "borderActive": "orange",
    "borderSubtle": "border",
    "diffAdded": "green",
    "diffRemoved": "red",
    "diffContext": "fg_muted",
    "diffHunkHeader": "blue",
    "syntaxComment": "fg_muted",
    "syntaxKeyword": "magenta",
    "syntaxFunction": "blue",
    "syntaxVariable": "fg",
    "syntaxString": "green",
    "syntaxNumber": "orange",
    "syntaxType": "teal",
    "syntaxOperator": "orange",
    "syntaxPunctuation": "fg_muted",
    "markdownHeading": "orange",
    "markdownCode": "teal",
    "markdownStrong": "fg",
    "markdownListItem": "orange"
  }
}
