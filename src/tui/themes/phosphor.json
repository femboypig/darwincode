{
  "$schema": "https://raw.githubusercontent.com/femboypig/darwincode/main/theme.json",
  "defs": {
    "bg": "#000000",
    "panel_bg": "#080808",
    "fg": "#e0e0e0",
    "fg_muted": "#666666",
    "red": "#ff4444",
    "orange": "#ff8c00",
    "yellow": "#ffd700",
    "green": "#00ff88",
    "teal": "#00ccaa",
    "blue": "#4488ff",
    "magenta": "#ff44ff",
    "cyan": "#00ddff",
    "border": "#1a1a1a"
  },
  "theme": {
    "primary": "green",
    "secondary": "fg_muted",
    "accent": "green",
    "error": "red",
    "warning": "orange",
    "success": "green",
    "info": "cyan",
    "text": "fg",
    "textMuted": "fg_muted",
    "background": "bg",
    "backgroundPanel": "panel_bg",
    "backgroundElement": "panel_bg",
    "border": "border",
    "borderActive": "green",
    "borderSubtle": "border",
    "diffAdded": "green",
    "diffRemoved": "red",
    "diffContext": "fg_muted",
    "diffHunkHeader": "cyan",
    "syntaxComment": "fg_muted",
    "syntaxKeyword": "green",
    "syntaxFunction": "cyan",
    "syntaxVariable": "fg",
    "syntaxString": "yellow",
    "syntaxNumber": "orange",
    "syntaxType": "teal",
    "syntaxOperator": "green",
    "syntaxPunctuation": "fg_muted",
    "markdownHeading": "green",
    "markdownCode": "cyan",
    "markdownStrong": "fg",
    "markdownListItem": "green"
  }
}
