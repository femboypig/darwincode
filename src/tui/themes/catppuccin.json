{
  "$schema": "https://raw.githubusercontent.com/femboypig/darwincode/main/theme.json",
  "defs": {
    "base": "#1e1e2e",
    "mantle": "#181825",
    "crust": "#11111b",
    "surface0": "#313244",
    "surface1": "#45475a",
    "surface2": "#585b70",
    "overlay0": "#6c7086",
    "text": "#cdd6f4",
    "subtext1": "#bac2de",
    "subtext0": "#a6adc8",
    "red": "#f38ba8",
    "maroon": "#eba0ac",
    "peach": "#fab387",
    "yellow": "#f9e2af",
    "green": "#a6e3a1",
    "teal": "#94e2d5",
    "blue": "#89b4fa",
    "sapphire": "#74c7ec",
    "mauve": "#cba6f7",
    "lavender": "#b4befe",

    "light_base": "#eff1f5",
    "light_mantle": "#e6e9ef",
    "light_crust": "#dce0e8",
    "light_surface0": "#ccd0da",
    "light_surface1": "#bcc0cc",
    "light_surface2": "#acb0be",
    "light_overlay0": "#9ca0b0",
    "light_text": "#4c4f69",
    "light_subtext1": "#5c5f77",
    "light_subtext0": "#6c6f85",
    "light_red": "#d20f39",
    "light_maroon": "#e64553",
    "light_peach": "#fe640b",
    "light_yellow": "#df8e1d",
    "light_green": "#40a02b",
    "light_teal": "#179299",
    "light_blue": "#1e66f5",
    "light_sapphire": "#209fb5",
    "light_mauve": "#8839ef",
    "light_lavender": "#7287fd"
  },
  "theme": {
    "primary": { "dark": "mauve", "light": "light_mauve" },
    "secondary": { "dark": "overlay0", "light": "light_overlay0" },
    "accent": { "dark": "blue", "light": "light_blue" },
    "error": { "dark": "red", "light": "light_red" },
    "warning": { "dark": "yellow", "light": "light_yellow" },
    "success": { "dark": "green", "light": "light_green" },
    "info": { "dark": "sapphire", "light": "light_sapphire" },
    "text": { "dark": "text", "light": "light_text" },
    "textMuted": { "dark": "subtext1", "light": "light_subtext1" },
    "background": { "dark": "base", "light": "light_base" },
    "backgroundPanel": { "dark": "mantle", "light": "light_mantle" },
    "backgroundElement": { "dark": "surface0", "light": "light_surface0" },
    "border": { "dark": "surface1", "light": "light_surface1" },
    "borderActive": { "dark": "lavender", "light": "light_lavender" },
    "borderSubtle": { "dark": "surface1", "light": "light_surface1" },
    "diffAdded": { "dark": "green", "light": "light_green" },
    "diffRemoved": { "dark": "red", "light": "light_red" },
    "diffContext": { "dark": "subtext1", "light": "light_subtext1" },
    "diffHunkHeader": { "dark": "blue", "light": "light_blue" },
    "diffHighlightAdded": { "dark": "green", "light": "light_green" },
    "diffHighlightRemoved": { "dark": "red", "light": "light_red" },
    "diffAddedBg": { "dark": "surface0", "light": "light_surface0" },
    "diffRemovedBg": { "dark": "#3a1c1f", "light": "#fadce0" },
    "diffContextBg": { "dark": "mantle", "light": "light_mantle" },
    "diffLineNumber": { "dark": "overlay0", "light": "light_overlay0" },
    "diffAddedLineNumberBg": { "dark": "surface0", "light": "light_surface0" },
    "diffRemovedLineNumberBg": { "dark": "#3a1c1f", "light": "#fadce0" },
    "markdownText": { "dark": "text", "light": "light_text" },
    "markdownHeading": { "dark": "mauve", "light": "light_mauve" },
    "markdownLink": { "dark": "sapphire", "light": "light_sapphire" },
    "markdownLinkText": { "dark": "sapphire", "light": "light_sapphire" },
    "markdownCode": { "dark": "green", "light": "light_green" },
    "markdownBlockQuote": { "dark": "subtext1", "light": "light_subtext1" },
    "markdownEmph": { "dark": "yellow", "light": "light_yellow" },
    "markdownStrong": { "dark": "peach", "light": "light_peach" },
    "markdownHorizontalRule": { "dark": "surface1", "light": "light_surface1" },
    "markdownListItem": { "dark": "blue", "light": "light_blue" },
    "markdownListEnumeration": { "dark": "blue", "light": "light_blue" },
    "markdownImage": { "dark": "sapphire", "light": "light_sapphire" },
    "markdownImageText": { "dark": "sapphire", "light": "light_sapphire" },
    "markdownCodeBlock": { "dark": "mantle", "light": "light_mantle" },
    "syntaxComment": { "dark": "surface2", "light": "light_surface2" },
    "syntaxKeyword": { "dark": "mauve", "light": "light_mauve" },
    "syntaxFunction": { "dark": "blue", "light": "light_blue" },
    "syntaxVariable": { "dark": "text", "light": "light_text" },
    "syntaxString": { "dark": "green", "light": "light_green" },
    "syntaxNumber": { "dark": "peach", "light": "light_peach" },
    "syntaxType": { "dark": "yellow", "light": "light_yellow" },
    "syntaxOperator": { "dark": "sapphire", "light": "light_sapphire" },
    "syntaxPunctuation": { "dark": "subtext1", "light": "light_subtext1" }
  }
}
