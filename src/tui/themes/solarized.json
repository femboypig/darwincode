{
  "$schema": "https://raw.githubusercontent.com/femboypig/darwincode/main/theme.json",
  "defs": {
    "bg": "#002b36",
    "panel_bg": "#073642",
    "fg": "#93a1a1",
    "fg_muted": "#586e75",
    "red": "#dc322f",
    "orange": "#cb4b16",
    "yellow": "#b58900",
    "green": "#859900",
    "teal": "#2aa198",
    "blue": "#268bd2",
    "magenta": "#d33682",
    "violet": "#6c71c4",
    "border": "#586e75",

    "light_bg": "#fdf6e3",
    "light_panel_bg": "#eee8d5",
    "light_fg": "#586e75",
    "light_fg_muted": "#93a1a1",
    "light_red": "#dc322f",
    "light_orange": "#cb4b16",
    "light_yellow": "#b58900",
    "light_green": "#859900",
    "light_teal": "#2aa198",
    "light_blue": "#268bd2",
    "light_magenta": "#d33682",
    "light_violet": "#6c71c4",
    "light_border": "#93a1a1"
  },
  "theme": {
    "primary": { "dark": "blue", "light": "light_blue" },
    "secondary": { "dark": "fg_muted", "light": "light_fg_muted" },
    "accent": { "dark": "magenta", "light": "light_magenta" },
    "error": { "dark": "red", "light": "light_red" },
    "warning": { "dark": "orange", "light": "light_orange" },
    "success": { "dark": "green", "light": "light_green" },
    "info": { "dark": "teal", "light": "light_teal" },
    "text": { "dark": "fg", "light": "light_fg" },
    "textMuted": { "dark": "fg_muted", "light": "light_fg_muted" },
    "background": { "dark": "bg", "light": "light_bg" },
    "backgroundPanel": { "dark": "panel_bg", "light": "light_panel_bg" },
    "backgroundElement": { "dark": "panel_bg", "light": "light_panel_bg" },
    "border": { "dark": "border", "light": "light_border" },
    "borderActive": { "dark": "yellow", "light": "light_yellow" },
    "borderSubtle": { "dark": "border", "light": "light_border" },
    "diffAdded": { "dark": "green", "light": "light_green" },
    "diffRemoved": { "dark": "red", "light": "light_red" },
    "diffContext": { "dark": "fg_muted", "light": "light_fg_muted" },
    "diffHunkHeader": { "dark": "blue", "light": "light_blue" },
    "diffHighlightAdded": { "dark": "green", "light": "light_green" },
    "diffHighlightRemoved": { "dark": "red", "light": "light_red" },
    "diffAddedBg": { "dark": "#073642", "light": "#eee8d5" },
    "diffRemovedBg": { "dark": "#4a1f1c", "light": "#fbe3e6" },
    "diffContextBg": { "dark": "panel_bg", "light": "light_panel_bg" },
    "diffLineNumber": { "dark": "fg_muted", "light": "light_fg_muted" },
    "diffAddedLineNumberBg": { "dark": "#073642", "light": "#eee8d5" },
    "diffRemovedLineNumberBg": { "dark": "#4a1f1c", "light": "#fbe3e6" },
    "markdownText": { "dark": "fg", "light": "light_fg" },
    "markdownHeading": { "dark": "yellow", "light": "light_yellow" },
    "markdownLink": { "dark": "teal", "light": "light_teal" },
    "markdownLinkText": { "dark": "teal", "light": "light_teal" },
    "markdownCode": { "dark": "green", "light": "light_green" },
    "markdownBlockQuote": { "dark": "fg_muted", "light": "light_fg_muted" },
    "markdownEmph": { "dark": "yellow", "light": "light_yellow" },
    "markdownStrong": { "dark": "orange", "light": "light_orange" },
    "markdownHorizontalRule": { "dark": "border", "light": "light_border" },
    "markdownListItem": { "dark": "blue", "light": "light_blue" },
    "markdownListEnumeration": { "dark": "blue", "light": "light_blue" },
    "markdownImage": { "dark": "teal", "light": "light_teal" },
    "markdownImageText": { "dark": "teal", "light": "light_teal" },
    "markdownCodeBlock": { "dark": "panel_bg", "light": "light_panel_bg" },
    "syntaxComment": { "dark": "fg_muted", "light": "light_fg_muted" },
    "syntaxKeyword": { "dark": "green", "light": "light_green" },
    "syntaxFunction": { "dark": "blue", "light": "light_blue" },
    "syntaxVariable": { "dark": "fg", "light": "light_fg" },
    "syntaxString": { "dark": "teal", "light": "light_teal" },
    "syntaxNumber": { "dark": "violet", "light": "light_violet" },
    "syntaxType": { "dark": "yellow", "light": "light_yellow" },
    "syntaxOperator": { "dark": "magenta", "light": "light_magenta" },
    "syntaxPunctuation": { "dark": "fg", "light": "light_fg" }
  }
}
